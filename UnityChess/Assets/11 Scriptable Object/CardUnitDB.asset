  effects:
  - effectId: PawnGeneric
    name: "\uACF5\uACA9 \uC9C0\uB839"
    text: "\uC120\uD0DD\uD55C \uC544\uAD70 \uC720\uB2DB\uC774 \uADF8 \uC720\uB2DB\uC758
      \uC774\uB3D9 \uBC94\uC704 \uB0B4 \uC801\uC744 \uD558\uB098 \uC120\uD0DD\uD574
      \uACF5\uACA9\uD569\uB2C8\uB2E4."
  - effectId: 
    name: 
    text: 
  - effectId: Or_L
    name: "\uC81C\uC655\uC758 \uC704\uC5C4"
    text: "\uCE74\uB4DC\uB97C \uD55C \uC7A5 \uBF51\uC2B5\uB2C8\uB2E4. \uC544\uAD70
      \uC720\uB2DB\uC744 \uC120\uD0DD\uD574 \uCCB4\uB825\uC744 1 \uD68C\uBCF5\uC2DC\uD0B5\uB2C8\uB2E4."
  - effectId: Or_B
    name: "\uCD9C\uADFC\uC774\uB2E4"
    text: "\uC544\uAD70 \uB9AC\uB354\uB97C \uC774 \uC720\uB2DB\uC758 \uC774\uB3D9\uBC94\uC704
      \uC548 \uC6D0\uD558\uB294 \uCE78\uC73C\uB85C \uC774\uB3D9\uC2DC\uD0B5\uB2C8\uB2E4."
  - effectId: Or_N
    name: "\uD48D\uCC28 \uB3CC\uACA9"
    text: "\uC774\uB3D9\uBC94\uC704 \uB0B4 \uC801\uC744 \uD558\uB098 \uC120\uD0DD\uD574
      \uACF5\uACA9\uD569\uB2C8\uB2E4. \uC801 \uC720\uB2DB\uC774 \uC774 \uACF5\uACA9\uC73C\uB85C
      \uD30C\uAD34\uB418\uC5C8\uB2E4\uBA74 \uC774\uB3D9\uBC94\uC704 \uB0B4 \uBAA8\uB4E0
      \uC801\uC744 \uACF5\uACA9\uD569\uB2C8\uB2E4."
  - effectId: Or_R
    name: "\uBFCC\uB9AC \uBC15\uAE30"
    text: "\uC774 \uC720\uB2DB\uC774 \uC774\uBC88 \uD134 \uAE30\uBCF8 \uC774\uB3D9\uC744
      \uC218\uD589\uD558\uC9C0 \uC54A\uC558\uB2E4\uBA74, \uC774\uB3D9\uBC94\uC704
      \uB0B4 \uC120\uD0DD\uB41C \uC801 \uD558\uB098\uC640 \uC774 \uC720\uB2DB\uC740
      \uB2E4\uC74C \uC0C1\uB300 \uD134 \uC885\uB8CC\uAE4C\uC9C0 \uAE30\uBCF8 \uC774\uB3D9\uC744
      \uC218\uD589\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
  - effectId: 
    name: 
    text: 
  - effectId: Cl_L
    name: "\uC11C\uB9AC \uC601\uC5ED"
    text: "\uCE74\uB4DC\uB97C \uD55C \uC7A5 \uBF51\uC2B5\uB2C8\uB2E4. \uC774\uB3D9\uBC94\uC704
      \uB0B4 \uC544\uAD70\uC744 \uD558\uB098 \uC120\uD0DD\uD574 \uCCB4\uB825\uC744
      3 \uD68C\uBCF5\uC2DC\uD0B5\uB2C8\uB2E4."
  - effectId: Cl_B
    name: "\uB77C\uC774\uD2B8\uB2DD \uCCB4\uC778"
    text: "\uC774\uB3D9\uBC94\uC704 \uC548\uC5D0 \uC720\uB2DB\uC774 3\uAE30 \uC774\uC0C1
      \uC874\uC7AC\uD55C\uB2E4\uBA74 \uD134 \uC885\uB8CC\uC2DC\uAE4C\uC9C0 \uACF5\uACA9\uB825\uC744
      +1 \uC5BB\uC2B5\uB2C8\uB2E4. \uC774\uB3D9\uBC94\uC704 \uB0B4 \uC801\uC744 \uBAA8\uB450
      \uACF5\uACA9\uD569\uB2C8\uB2E4."
  - effectId: Cl_N
    name: "\uC5BC\uC74C \uCE7C\uB0A0"
    text: "\uC774\uB3D9\uBC94\uC704 \uB0B4 \uC801\uC744 \uD558\uB098 \uC120\uD0DD\uD574
      \uACF5\uACA9\uD569\uB2C8\uB2E4. \uACF5\uACA9\uBC1B\uC740 \uC801\uC740 \uB2E4\uC74C
      \uD134 \uB05D\uAE4C\uC9C0 \uACF5\uACA9\uB825 -3\uC744 \uC5BB\uC2B5\uB2C8\uB2E4."
  - effectId: Cl_R
    name: "\uBC88\uAC1C \uB3CC\uACA9"
    text: "\uC774\uB3D9\uBC94\uC704 \uB0B4 \uC801\uC744 \uD558\uB098 \uC120\uD0DD\uD574
      \uACF5\uACA9\uD569\uB2C8\uB2E4. \uC120\uD0DD\uD55C \uC801 \uBC29\uD5A5\uC73C\uB85C
      \uD55C \uCE78 \uC774\uB3D9\uD569\uB2C8\uB2E4. \uC774\uB3D9\uD560 \uC218 \uC5C6\uC5C8\uB2E4\uBA74,
      \uC120\uD0DD\uD55C \uC801\uC744 \uB2E4\uC2DC \uACF5\uACA9\uD569\uB2C8\uB2E4."
  events:
  - eventId: Or_L
